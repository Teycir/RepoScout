{
  "name": "reposcout",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "pages:build": "opennextjs-cloudflare build",
    "deploy": "npm run pages:build && wrangler deploy --config wrangler.jsonc",
    "deploy:scan": "wrangler deploy --config wrangler.scan.toml",
    "db:migrate": "wrangler d1 execute reposcout --file=migrations/schema.sql --config=wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 execute reposcout --remote --file=migrations/schema.sql --config=wrangler.jsonc",
    "db:seed-tokens": "npx tsx scripts/seed-tokens.ts",
    "db:seed-tokens:remote": "npx tsx scripts/seed-tokens.ts --remote",
    "db:seed-repos": "npx tsx scripts/seed-repos.ts",
    "db:seed-repos:remote": "npx tsx scripts/seed-repos.ts --remote",
    "compile-patterns": "npx tsx scripts/compile-patterns.ts",
    "compile-patterns:all": "npx tsx scripts/compile-patterns.ts --include-others",
    "test:e2e": "NODE_NO_WARNINGS=1 npx tsx --test tests/engine.e2e.test.ts",
    "test:local-e2e": "NODE_NO_WARNINGS=1 npx tsx tests/local-e2e.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.38",
    "@langchain/langgraph": "^0.2.45",
    "@opennextjs/cloudflare": "^1.19.10",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.4.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.169.0",
    "autoprefixer": "^10.5.0",
    "better-sqlite3": "^12.10.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "5.9.3",
    "wrangler": "^4.86.0",
    "yaml": "^2.9.0"
  }
}
