{
  "name": "reposcout",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile-patterns": "npx tsx scripts/compile-patterns.ts",
    "compile-patterns:all": "npx tsx scripts/compile-patterns.ts --include-others",
    "scan": "node --no-warnings cli/dist/cli/repo-cli.js scan",
    "workflow": "node --no-warnings cli/dist/cli/repo-cli.js workflow",
    "cli": "node --no-warnings cli/dist/cli/repo-cli.js",
    "cli:dev": "NODE_NO_WARNINGS=1 npx tsx cli/repo-cli.ts",
    "build:cli": "cd cli && npx tsc",
    "test:e2e": "NODE_NO_WARNINGS=1 npx tsx --test tests/engine.e2e.test.ts",
    "test:local-e2e": "NODE_NO_WARNINGS=1 npx tsx tests/local-e2e.ts",
    "test:crawler": "NODE_NO_WARNINGS=1 npx tsx tests/crawler-e2e.ts",
    "test:full-e2e": "NODE_NO_WARNINGS=1 npx tsx tests/full-e2e-verification.ts",
    "test:crawler-stress": "NODE_NO_WARNINGS=1 npx tsx tests/crawler-stress-test.ts",
    "test:window-opt": "NODE_NO_WARNINGS=1 npx tsx tests/crawler-window-optimizer.ts",
    "test:workflow": "NODE_NO_WARNINGS=1 npx tsx tests/run-workflow.ts",
    "test:cli-full": "NODE_NO_WARNINGS=1 npx tsx tests/cli-full-test.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.38",
    "@langchain/langgraph": "^0.2.45",
    "better-sqlite3": "^12.10.0",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "5.9.3",
    "yaml": "^2.9.0"
  }
}
