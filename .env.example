# RepoScout — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── GitHub PATs (classic, read-only public_repo scope) ───────────────────────
GITHUB_TOKEN_1=
GITHUB_TOKEN_2=
GITHUB_TOKEN_3=
GITHUB_TOKEN_4=
GITHUB_TOKEN_5=
GITHUB_TOKEN_6=
GITHUB_TOKEN_7=

# ── GrayhatWarfare API keys ───────────────────────────────────────────────────
GRAYHATWARFARE_1=
GRAYHATWARFARE_2=
# ... up to GRAYHATWARFARE_18

# ── URLScan API keys ──────────────────────────────────────────────────────────
URLSCAN_1=
URLSCAN_2=
# ... up to URLSCAN_12

# ── ProtonVPN (stealth scanning) ──────────────────────────────────────────────
PROTONVPN_USERNAME=
PROTONVPN_PASSWORD=
